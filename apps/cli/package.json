{
  "name": "ainong",
  "version": "0.1.0",
  "description": "Ainong CLI: Dreamina-compatible account-pool wrapper.",
  "type": "module",
  "homepage": "https://github.com/wg5x/ai-nong#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/wg5x/ai-nong.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/wg5x/ai-nong/issues"
  },
  "keywords": [
    "ainong",
    "dreamina",
    "jimeng",
    "cli",
    "ai-video",
    "account-pool"
  ],
  "bin": {
